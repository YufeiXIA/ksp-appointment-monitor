SLOW_MO_MS=75

FIRST_NAME=
MIDDLE_NAME=
LAST_NAME=
DATE_OF_BIRTH=
PHONE=
EMAIL=

# Optional fields; fill them if the KSP page asks for them.
ADDRESS=
CITY=
STATE=KY
ZIP=
LICENSE_OR_PERMIT_NUMBER=
